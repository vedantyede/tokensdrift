{
  "name": "tokendrift",
  "version": "0.1.1",
  "description": "Scan codebases for design system drift and generate a scored, shareable report.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "tokendrift": "dist/index.js"
  },
  "exports": {
    "./report": "./src/report.ts",
    "./types": "./src/types.ts"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "tsx --test test/**/*.test.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js=\"#!/usr/bin/env node\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {}
}
